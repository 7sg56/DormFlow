# ================================
# Database
# ================================
DB_HOST=db
DB_USER=root
DB_PASSWORD=hostel
DB_NAME=hostel_mgmt
DB_PORT=3306

# ================================
# Backend
# ================================
PORT=5001
NODE_ENV=development

# ================================
# Prisma
# ================================
DATABASE_URL="mysql://root:hostel@db:3306/hostel_mgmt"

# ================================
# Redis
# ================================
REDIS_HOST=redis
REDIS_PORT=6379

# ================================
# Auth
# ================================
JWT_SECRET=change_me_to_a_secure_random_string
HMAC_SECRET=change_me_to_a_secure_random_string

# ================================
# Sentry (optional)
# ================================
SENTRY_DSN=

# ================================
# Frontend
# ================================
NEXT_PUBLIC_API_URL=http://localhost:5001/api
