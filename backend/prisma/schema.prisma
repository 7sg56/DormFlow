generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  // When running prisma CLI locally, use: DATABASE_URL=... npx prisma generate
  // Or set DATABASE_URL in the root .env file
}

// ============================================================
// TABLE 1: hostel
// ============================================================
model hostel {
  hostel_id      String   @id @default(uuid()) @db.Char(36)
  hostel_name    String   @db.VarChar(100)
  type           String   @db.VarChar(50)
  total_floors   Int
  address        String?  @db.VarChar(255)
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(100)
  pincode        String?  @db.VarChar(10)
  established_year Int?   @db.Year
  registration_no  String? @unique @db.VarChar(100)
  warden_name    String?  @db.VarChar(100)
  warden_phone   String?  @db.VarChar(15)
  warden_email   String?  @db.VarChar(100)
  office_phone   String?  @db.VarChar(15)
  emergency_phone String? @db.VarChar(15)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  rooms                room[]
  technicians          technician[]
  messes               mess[]
  laundries            laundry[]
  facilities           facility[]
  notice_boards        notice_board[]
  maintenance_schedules maintenance_schedule[]
  stores               store[]
}

// ============================================================
// TABLE 2: student
// ============================================================
model student {
  student_id           String   @id @default(uuid()) @db.Char(36)
  reg_no               String   @unique @db.VarChar(50)
  first_name           String   @db.VarChar(100)
  last_name            String   @db.VarChar(100)
  date_of_birth        DateTime @db.Date
  gender               String   @db.VarChar(10)
  phone_primary        String?  @db.VarChar(15)
  phone_secondary      String?  @db.VarChar(15)
  email_personal       String?  @db.VarChar(100)
  email_institutional  String?  @db.VarChar(100)
  department           String?  @db.VarChar(100)
  course               String?  @db.VarChar(100)
  academic_year        Int?
  semester             Int?
  blood_group          String?  @db.VarChar(5)
  permanent_address    String?  @db.Text
  current_address      String?  @db.Text
  city                 String?  @db.VarChar(100)
  state                String?  @db.VarChar(100)
  pincode              String?  @db.VarChar(10)
  admission_date       DateTime? @db.Date
  status               String   @default("Active") @db.VarChar(20)
  photo_url            String?  @db.VarChar(255)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  guardians            student_guardian[]
  allocations          allocation[]
  fee_payments         feepayment[]
  mess_subscriptions   mess_subscription[]
  laundry_requests     laundry_request[]
  access_logs          accesslog[]
  facility_bookings    facility_booking[]
  complaints           complaint[]
  visitor_logs         visitor_log[]
  store_purchases      store_purchase[]
  pharmacy_visits      pharmacy_visit[]
  gym_memberships      gym_membership[]
  emergency_requests   emergency_request[]
  auth_user            auth_user?

  @@index([reg_no], name: "idx_student_reg_no")
  @@index([department, course], name: "idx_student_dept_course")
  @@index([status], name: "idx_student_status")
}

// ============================================================
// TABLE 3: student_guardian
// ============================================================
model student_guardian {
  guardian_id        String   @id @default(uuid()) @db.Char(36)
  student_id         String   @db.Char(36)
  guardian_name      String   @db.VarChar(100)
  relation           String   @db.VarChar(50)
  phone              String?  @db.VarChar(15)
  email              String?  @db.VarChar(100)
  address            String?  @db.Text
  is_emergency_contact Boolean @default(false)

  student            student  @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@index([student_id, is_emergency_contact], name: "idx_sg_student")
}

// ============================================================
// TABLE 4: room
// ============================================================
model room {
  room_id        String   @id @default(uuid()) @db.Char(36)
  room_number    String   @db.VarChar(20)
  floor          Int
  capacity       Int
  room_type      String?  @db.VarChar(50)
  hostel_id      String   @db.Char(36)
  monthly_rent   Decimal? @db.Decimal(10, 2)
  area_sqft      Decimal? @db.Decimal(8, 2)
  facing         String?  @db.VarChar(20)
  room_condition String?  @default("Good") @db.VarChar(50)
  last_cleaned   DateTime? @db.Date
  last_maintained DateTime? @db.Date
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  hostel         hostel   @relation(fields: [hostel_id], references: [hostel_id], onDelete: Cascade)
  beds           bed[]
  complaints     complaint[]
  visitor_logs   visitor_log[]

  @@unique([hostel_id, room_number])
  @@index([hostel_id], name: "idx_room_hostel")
  @@index([room_type, monthly_rent], name: "idx_room_type_rent")
}

// ============================================================
// TABLE 5: bed
// ============================================================
model bed {
  bed_id           String   @id @default(uuid()) @db.Char(36)
  bed_number       String   @db.VarChar(20)
  room_id          String   @db.Char(36)
  bed_type         String?  @db.VarChar(50)
  condition_status String?  @default("Good") @db.VarChar(50)
  occupied         Boolean  @default(false)
  purchase_date    DateTime? @db.Date
  last_replaced    DateTime? @db.Date
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  room             room     @relation(fields: [room_id], references: [room_id], onDelete: Cascade)
  allocations      allocation[]

  @@unique([room_id, bed_number])
  @@index([room_id, occupied], name: "idx_bed_room_occupied")
}

// ============================================================
// TABLE 6: technician
// ============================================================
model technician {
  technician_id  String   @id @default(uuid()) @db.Char(36)
  name           String   @db.VarChar(100)
  specialization String?  @db.VarChar(100)
  phone          String?  @db.VarChar(15)
  email          String?  @db.VarChar(100)
  address        String?  @db.Text
  availability   String?  @db.VarChar(100)
  joining_date   DateTime? @db.Date
  employment_type String? @db.VarChar(30)
  salary         Decimal? @db.Decimal(10, 2)
  vendor_company String?  @db.VarChar(100)
  hostel_id      String?  @db.Char(36)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  hostel         hostel?  @relation(fields: [hostel_id], references: [hostel_id], onDelete: SetNull)
  complaints     complaint[]
  maintenance_schedules maintenance_schedule[]
}

// ============================================================
// TABLE 7: allocation
// ============================================================
model allocation {
  allocation_id  String   @id @default(uuid()) @db.Char(36)
  student_id     String   @db.Char(36)
  bed_id         String   @db.Char(36)
  start_date     DateTime @db.Date
  end_date       DateTime? @db.Date
  allocated_by   String?  @db.VarChar(100)
  reason         String?  @db.Text
  status         String   @default("Active") @db.VarChar(20)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  student        student  @relation(fields: [student_id], references: [student_id])
  bed            bed      @relation(fields: [bed_id], references: [bed_id])

  @@index([student_id, status], name: "idx_alloc_student_status")
  @@index([bed_id, status], name: "idx_alloc_bed_status")
  @@index([start_date, end_date], name: "idx_alloc_dates")
}

// ============================================================
// TABLE 8: feepayment
// ============================================================
model feepayment {
  payment_id     String   @id @default(uuid()) @db.Char(36)
  student_id     String   @db.Char(36)
  amount_due     Decimal  @db.Decimal(10, 2)
  paid_amount    Decimal  @default(0) @db.Decimal(10, 2)
  balance_due    Decimal? @db.Decimal(10, 2)
  semester       String?  @db.VarChar(20)
  fee_month      String?  @db.VarChar(20)
  payment_mode   String?  @db.VarChar(50)
  transaction_id String?  @db.VarChar(100)
  payment_date   DateTime?
  due_date       DateTime? @db.Date
  late_fee       Decimal  @default(0) @db.Decimal(10, 2)
  receipt_number String?  @db.VarChar(100)
  status         String   @default("Pending") @db.VarChar(20)
  remarks        String?  @db.Text
  approved_by    String?  @db.VarChar(100)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  student        student  @relation(fields: [student_id], references: [student_id])

  @@index([student_id], name: "idx_fp_student")
  @@index([due_date, status], name: "idx_fp_due_date_status")
  @@index([fee_month, semester], name: "idx_fp_month_semester")
}

// ============================================================
// TABLE 9: mess
// ============================================================
model mess {
  mess_id          String   @id @default(uuid()) @db.Char(36)
  mess_name        String   @db.VarChar(100)
  mess_type        String?  @db.VarChar(50)
  hostel_id        String   @db.Char(36)
  monthly_fee      Decimal? @db.Decimal(10, 2)
  capacity         Int?
  manager_name     String?  @db.VarChar(100)
  manager_phone    String?  @db.VarChar(15)
  hygiene_rating   Decimal? @db.Decimal(3, 1)
  last_inspection  DateTime? @db.Date
  license_number   String?  @db.VarChar(100)
  license_expiry   DateTime? @db.Date
  timing_breakfast String?  @db.VarChar(50)
  timing_lunch     String?  @db.VarChar(50)
  timing_snacks    String?  @db.VarChar(50)
  timing_dinner    String?  @db.VarChar(50)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  hostel           hostel   @relation(fields: [hostel_id], references: [hostel_id])
  subscriptions    mess_subscription[]
  menus            menu[]
}

// ============================================================
// TABLE 10: mess_subscription
// ============================================================
model mess_subscription {
  subscription_id String   @id @default(uuid()) @db.Char(36)
  student_id      String   @db.Char(36)
  mess_id         String   @db.Char(36)
  start_date      DateTime @db.Date
  end_date        DateTime? @db.Date
  meal_plan       String?  @db.VarChar(50)
  monthly_charge  Decimal? @db.Decimal(10, 2)
  status          String   @default("Active") @db.VarChar(20)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  student         student  @relation(fields: [student_id], references: [student_id])
  mess            mess     @relation(fields: [mess_id], references: [mess_id])

  @@index([student_id, status], name: "idx_ms_student_status")
  @@index([mess_id, status], name: "idx_ms_mess_status")
}

// ============================================================
// TABLE 11: menu
// ============================================================
model menu {
  menu_id        String   @id @default(uuid()) @db.Char(36)
  mess_id        String   @db.Char(36)
  day_of_week    String   @db.VarChar(10)
  meal_type      String   @db.VarChar(20)
  item_name      String   @db.VarChar(100)
  item_category  String?  @db.VarChar(50)
  cuisine_type   String?  @db.VarChar(50)
  is_veg         Boolean  @default(true)
  calories_approx Int?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  mess           mess     @relation(fields: [mess_id], references: [mess_id], onDelete: Cascade)

  @@index([mess_id, day_of_week, meal_type], name: "idx_menu_mess_day_meal")
}

// ============================================================
// TABLE 12: laundry
// ============================================================
model laundry {
  laundry_id      String   @id @default(uuid()) @db.Char(36)
  laundry_name    String   @db.VarChar(100)
  hostel_id       String   @db.Char(36)
  vendor_name     String?  @db.VarChar(100)
  vendor_phone    String?  @db.VarChar(15)
  vendor_email    String?  @db.VarChar(100)
  price_per_piece Decimal? @db.Decimal(8, 2)
  price_per_kg    Decimal? @db.Decimal(8, 2)
  service_types   String?  @db.VarChar(255)
  operating_days  String?  @db.VarChar(100)
  timing_open     DateTime? @db.Time(0)
  timing_close    DateTime? @db.Time(0)
  contract_start  DateTime? @db.Date
  contract_end    DateTime? @db.Date
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  hostel          hostel   @relation(fields: [hostel_id], references: [hostel_id])
  requests        laundry_request[]
}

// ============================================================
// TABLE 13: laundry_request
// ============================================================
model laundry_request {
  request_id       String   @id @default(uuid()) @db.Char(36)
  student_id       String   @db.Char(36)
  laundry_id       String   @db.Char(36)
  pickup_date      DateTime @db.Date
  delivery_date    DateTime? @db.Date
  items_description String? @db.Text
  total_pieces     Int?
  total_weight_kg  Decimal? @db.Decimal(8, 2)
  total_charge     Decimal? @db.Decimal(10, 2)
  service_type     String?  @db.VarChar(50)
  status           String   @default("Pending") @db.VarChar(30)
  payment_status   String   @default("Unpaid") @db.VarChar(20)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  student          student  @relation(fields: [student_id], references: [student_id])
  laundry          laundry  @relation(fields: [laundry_id], references: [laundry_id])

  @@index([student_id], name: "idx_lr_student")
  @@index([laundry_id, status], name: "idx_lr_laundry_status")
  @@index([payment_status], name: "idx_lr_payment_status")
}

// ============================================================
// TABLE 14: accesslog
// ============================================================
model accesslog {
  log_id           String   @id @default(uuid()) @db.Char(36)
  student_id       String   @db.Char(36)
  entry_time       DateTime
  exit_time        DateTime?
  duration_minutes Int?
  is_overnight     Boolean?
  is_late_entry    Boolean  @default(false)
  gate_number      String?  @db.VarChar(20)
  guard_name       String?  @db.VarChar(100)
  purpose          String?  @db.VarChar(100)
  remarks          String?  @db.Text
  created_at       DateTime @default(now())

  student          student  @relation(fields: [student_id], references: [student_id])

  @@index([student_id, entry_time], name: "idx_al_student_entry")
  @@index([is_late_entry, entry_time], name: "idx_al_late")
}

// ============================================================
// TABLE 15: facility
// ============================================================
model facility {
  facility_id      String   @id @default(uuid()) @db.Char(36)
  facility_name    String   @db.VarChar(100)
  facility_type    String?  @db.VarChar(50)
  hostel_id        String   @db.Char(36)
  capacity         Int?
  operating_days   String?  @db.VarChar(100)
  timing_open      DateTime? @db.Time(0)
  timing_close     DateTime? @db.Time(0)
  in_charge_name   String?  @db.VarChar(100)
  in_charge_phone  String?  @db.VarChar(15)
  condition_status String?  @default("Good") @db.VarChar(50)
  last_maintained  DateTime? @db.Date
  is_operational   Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  hostel           hostel   @relation(fields: [hostel_id], references: [hostel_id])
  bookings         facility_booking[]
}

// ============================================================
// TABLE 16: facility_booking
// ============================================================
model facility_booking {
  booking_id       String   @id @default(uuid()) @db.Char(36)
  facility_id      String   @db.Char(36)
  student_id       String   @db.Char(36)
  booking_date     DateTime @db.Date
  slot_start       DateTime @db.Time(0)
  slot_end         DateTime @db.Time(0)
  duration_minutes Int?
  purpose          String?  @db.VarChar(100)
  status           String   @default("Confirmed") @db.VarChar(20)
  created_at       DateTime @default(now())

  facility         facility @relation(fields: [facility_id], references: [facility_id])
  student          student  @relation(fields: [student_id], references: [student_id])

  @@index([facility_id, booking_date, slot_start, slot_end], name: "idx_fb_facility_date_slot")
  @@index([student_id, booking_date], name: "idx_fb_student_date")
}

// ============================================================
// TABLE 17: complaint
// ============================================================
model complaint {
  complaint_id     String   @id @default(uuid()) @db.Char(36)
  student_id       String   @db.Char(36)
  room_id          String?  @db.Char(36)
  technician_id    String?  @db.Char(36)
  description      String   @db.Text
  complaint_type   String?  @db.VarChar(100)
  priority         String   @default("Medium") @db.VarChar(20)
  status           String   @default("Open") @db.VarChar(30)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  resolved_at      DateTime?
  is_resolved      Boolean?
  resolution_notes String?  @db.Text
  cost_incurred    Decimal  @default(0) @db.Decimal(10, 2)

  student          student    @relation(fields: [student_id], references: [student_id])
  room             room?      @relation(fields: [room_id], references: [room_id], onDelete: SetNull)
  technician       technician? @relation(fields: [technician_id], references: [technician_id], onDelete: SetNull)

  @@index([technician_id, status], name: "idx_comp_tech_status")
  @@index([priority, status], name: "idx_comp_priority_status")
}

// ============================================================
// TABLE 18: visitor_log
// ============================================================
model visitor_log {
  visitor_id             String   @id @default(uuid()) @db.Char(36)
  visitor_name           String   @db.VarChar(100)
  visitor_phone          String?  @db.VarChar(15)
  id_proof_type          String?  @db.VarChar(50)
  id_proof_number        String?  @db.VarChar(100)
  student_id             String   @db.Char(36)
  room_id                String?  @db.Char(36)
  relation_to_student    String?  @db.VarChar(50)
  purpose                String?  @db.Text
  entry_time             DateTime
  exit_time              DateTime?
  visit_duration_minutes Int?
  guard_name             String?  @db.VarChar(100)
  gate_number            String?  @db.VarChar(20)
  approved_by            String?  @db.VarChar(100)
  created_at             DateTime @default(now())

  student                student  @relation(fields: [student_id], references: [student_id])
  room                   room?    @relation(fields: [room_id], references: [room_id], onDelete: SetNull)

  @@index([student_id, entry_time], name: "idx_vl_student_entry")
}

// ============================================================
// TABLE 19: notice_board
// ============================================================
model notice_board {
  notice_id       String   @id @default(uuid()) @db.Char(36)
  hostel_id       String   @db.Char(36)
  title           String   @db.VarChar(255)
  content         String?  @db.Text
  category        String?  @db.VarChar(50)
  target_audience String?  @db.VarChar(50)
  posted_by       String?  @db.VarChar(100)
  posted_at       DateTime @default(now())
  expiry_date     DateTime? @db.Date
  attachment_url  String?  @db.VarChar(255)

  hostel          hostel   @relation(fields: [hostel_id], references: [hostel_id])

  @@index([hostel_id, expiry_date], name: "idx_nb_hostel_expiry")
}

// ============================================================
// TABLE 20: maintenance_schedule
// ============================================================
model maintenance_schedule {
  schedule_id      String   @id @default(uuid()) @db.Char(36)
  hostel_id        String   @db.Char(36)
  area_type        String?  @db.VarChar(50)
  area_id          String?  @db.Char(36)
  maintenance_type String?  @db.VarChar(100)
  scheduled_date   DateTime @db.Date
  completed_date   DateTime? @db.Date
  technician_id    String?  @db.Char(36)
  status           String   @default("Scheduled") @db.VarChar(20)
  notes            String?  @db.Text
  cost             Decimal? @db.Decimal(10, 2)
  created_at       DateTime @default(now())

  hostel           hostel     @relation(fields: [hostel_id], references: [hostel_id])
  technician       technician? @relation(fields: [technician_id], references: [technician_id], onDelete: SetNull)

  @@index([hostel_id, status], name: "idx_msch_hostel_status")
  @@index([technician_id], name: "idx_msch_tech")
  @@index([scheduled_date], name: "idx_msch_scheduled_date")
}

// ============================================================
// TABLE 21: store
// ============================================================
model store {
  store_id       String   @id @default(uuid()) @db.Char(36)
  store_name     String   @db.VarChar(100)
  hostel_id      String   @db.Char(36)
  manager_name   String?  @db.VarChar(100)
  manager_phone  String?  @db.VarChar(15)
  store_type     String?  @db.VarChar(50)
  timing_open    DateTime? @db.Time(0)
  timing_close   DateTime? @db.Time(0)
  is_operational Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  hostel         hostel   @relation(fields: [hostel_id], references: [hostel_id])
  purchases      store_purchase[]
}

// ============================================================
// TABLE 22: store_purchase
// ============================================================
model store_purchase {
  purchase_id      String   @id @default(uuid()) @db.Char(36)
  student_id       String   @db.Char(36)
  store_id         String   @db.Char(36)
  item_description String   @db.Text
  quantity         Int      @default(1)
  total_amount     Decimal  @db.Decimal(10, 2)
  payment_mode     String?  @db.VarChar(50)
  purchase_date    DateTime @default(now())

  student          student  @relation(fields: [student_id], references: [student_id])
  store            store    @relation(fields: [store_id], references: [store_id])

  @@index([student_id], name: "idx_sp_student")
  @@index([store_id, purchase_date], name: "idx_sp_store_date")
}

// ============================================================
// TABLE 23: pharmacy
// ============================================================
model pharmacy {
  pharmacy_id      String   @id @default(uuid()) @db.Char(36)
  pharmacy_name    String   @db.VarChar(100)
  address          String?  @db.VarChar(255)
  pharmacist_name  String?  @db.VarChar(100)
  pharmacist_phone String?  @db.VarChar(15)
  license_number   String?  @db.VarChar(100)
  license_expiry   DateTime? @db.Date
  timing_open      DateTime? @db.Time(0)
  timing_close     DateTime? @db.Time(0)
  is_24hr          Boolean  @default(false)
  emergency_available Boolean @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  visits           pharmacy_visit[]
}

// ============================================================
// TABLE 24: pharmacy_visit
// ============================================================
model pharmacy_visit {
  visit_id             String   @id @default(uuid()) @db.Char(36)
  student_id           String   @db.Char(36)
  pharmacy_id          String   @db.Char(36)
  visit_date           DateTime @default(now())
  prescription_details String?  @db.Text
  medicines_issued     String?  @db.Text
  total_cost           Decimal? @db.Decimal(10, 2)
  payment_status       String   @default("Paid") @db.VarChar(20)

  student              student  @relation(fields: [student_id], references: [student_id])
  pharmacy             pharmacy @relation(fields: [pharmacy_id], references: [pharmacy_id])

  @@index([student_id], name: "idx_pv_student")
  @@index([payment_status], name: "idx_pv_payment_status")
}

// ============================================================
// TABLE 25: restaurant
// ============================================================
model restaurant {
  restaurant_id     String   @id @default(uuid()) @db.Char(36)
  restaurant_name   String   @db.VarChar(100)
  location          String?  @db.VarChar(255)
  cuisine_type      String?  @db.VarChar(100)
  manager_name      String?  @db.VarChar(100)
  manager_phone     String?  @db.VarChar(15)
  capacity          Int?
  timing_open       DateTime? @db.Time(0)
  timing_close      DateTime? @db.Time(0)
  avg_cost_per_meal Decimal? @db.Decimal(8, 2)
  rating            Decimal? @db.Decimal(3, 1)
  is_operational    Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

// ============================================================
// TABLE 26: gym
// ============================================================
model gym {
  gym_id            String   @id @default(uuid()) @db.Char(36)
  gym_name          String   @db.VarChar(100)
  location          String?  @db.VarChar(255)
  trainer_name      String?  @db.VarChar(100)
  trainer_phone     String?  @db.VarChar(15)
  capacity          Int?
  monthly_fee       Decimal? @db.Decimal(10, 2)
  equipment_summary String?  @db.Text
  timing_open       DateTime? @db.Time(0)
  timing_close      DateTime? @db.Time(0)
  is_operational    Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  memberships       gym_membership[]
}

// ============================================================
// TABLE 27: gym_membership
// ============================================================
model gym_membership {
  membership_id String   @id @default(uuid()) @db.Char(36)
  student_id    String   @db.Char(36)
  gym_id        String   @db.Char(36)
  start_date    DateTime @db.Date
  end_date      DateTime? @db.Date
  fee_paid      Decimal? @db.Decimal(10, 2)
  status        String   @default("Active") @db.VarChar(20)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  student       student  @relation(fields: [student_id], references: [student_id])
  gym           gym      @relation(fields: [gym_id], references: [gym_id])

  @@index([student_id, status], name: "idx_gm_student_status")
  @@index([gym_id, end_date], name: "idx_gm_gym_end_date")
}

// ============================================================
// TABLE 28: ambulance_service
// ============================================================
model ambulance_service {
  ambulance_id      String   @id @default(uuid()) @db.Char(36)
  vehicle_number    String   @unique @db.VarChar(20)
  driver_name       String?  @db.VarChar(100)
  driver_phone      String?  @db.VarChar(15)
  hospital_name     String?  @db.VarChar(100)
  hospital_address  String?  @db.VarChar(255)
  hospital_phone    String?  @db.VarChar(15)
  is_available      Boolean  @default(true)
  last_service_date DateTime? @db.Date
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  emergency_requests emergency_request[]
}

// ============================================================
// TABLE 29: emergency_request
// ============================================================
model emergency_request {
  request_id            String   @id @default(uuid()) @db.Char(36)
  student_id            String   @db.Char(36)
  ambulance_id          String?  @db.Char(36)
  request_time          DateTime @default(now())
  pickup_time           DateTime?
  hospital_reached_time DateTime?
  response_minutes      Int?
  emergency_type        String?  @db.VarChar(100)
  description           String?  @db.Text
  status                String   @default("Requested") @db.VarChar(30)
  notes                 String?  @db.Text
  created_at            DateTime @default(now())

  student               student           @relation(fields: [student_id], references: [student_id])
  ambulance             ambulance_service? @relation(fields: [ambulance_id], references: [ambulance_id], onDelete: SetNull)

  @@index([student_id], name: "idx_er_student")
  @@index([ambulance_id], name: "idx_er_ambulance")
}

// ============================================================
// TABLE 30: auth_user
// ============================================================
model auth_user {
  user_id       String    @id @default(uuid()) @db.Char(36)
  student_id    String?   @unique @db.Char(36)
  email         String    @unique @db.VarChar(100)
  password_hash String    @db.VarChar(255)
  role          auth_user_role @default(student)
  is_active     Boolean   @default(true)
  last_login    DateTime?
  refresh_token String?   @db.VarChar(500)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  student       student?  @relation(fields: [student_id], references: [student_id], onDelete: SetNull)
  audit_logs    audit_log[]
  idempotency_keys idempotency_key[]

  @@index([email], name: "idx_auth_email")
  @@index([role, is_active], name: "idx_auth_role")
  @@index([student_id], name: "idx_auth_student")
}

enum auth_user_role {
  admin
  warden
  student
}

// ============================================================
// TABLE 31: audit_log
// ============================================================
model audit_log {
  log_id      String    @id @default(uuid()) @db.Char(36)
  user_id     String?   @db.Char(36)
  table_name  String    @db.VarChar(50)
  record_id   String    @db.Char(36)
  action      audit_log_action
  old_values  Json?
  new_values  Json?
  ip_address  String?   @db.VarChar(45)
  user_agent  String?   @db.VarChar(255)
  created_at  DateTime  @default(now())

  user        auth_user? @relation(fields: [user_id], references: [user_id], onDelete: SetNull)

  @@index([table_name, record_id], name: "idx_audit_table_record")
  @@index([user_id], name: "idx_audit_user")
  @@index([created_at], name: "idx_audit_created")
  @@index([action, table_name], name: "idx_audit_action")
}

enum audit_log_action {
  INSERT
  UPDATE
  DELETE
}

// ============================================================
// TABLE 32: idempotency_key
// ============================================================
model idempotency_key {
  idempotency_key String   @id @db.VarChar(255)
  user_id         String?  @db.Char(36)
  request_path    String   @db.VarChar(255)
  request_hash    String   @db.VarChar(64)
  response_code   Int?
  response_body   Json?
  created_at      DateTime @default(now())
  expires_at      DateTime

  user            auth_user? @relation(fields: [user_id], references: [user_id], onDelete: SetNull)

  @@index([expires_at], name: "idx_idem_expires")
  @@index([user_id], name: "idx_idem_user")
}
